flowchart LR
    %% Wenvy current architecture snapshot.
    %% Secret plaintext is intentionally present only on trusted client devices.

    subgraph Client["Trusted client boundary"]
        Terminal["Developer device<br/>Wenvy terminal client<br/>Local .wenvy metadata"]
        Browser["Web browser<br/>Governance dashboard"]
        CI["CI/CD runner<br/>Scoped service token<br/>Machine key pair"]
    end

    subgraph External["External identity and delivery systems"]
        Email["Email provider<br/>Magic links and invites"]
        GitHub["GitHub App<br/>Read-only org/team membership<br/>Signed webhooks"]
    end

    subgraph Edge["Cloudflare edge"]
        HTTP_Edge["HTTPS edge<br/>DNS, TLS, WAF<br/>Rate limiting, Turnstile"]
        SSH_Edge["Optional SSH TCP edge<br/>Cloudflare Tunnel or Spectrum<br/>Compatibility path only"]
        Shield["Optional enterprise controls<br/>API Shield, mTLS<br/>Cloudflare Access"]
    end

    subgraph Control["Cloudflare Worker control plane"]
        Worker["Dashboard + API Worker<br/>React/Vite static assets<br/>Hono API routes<br/>OpenAPI 3.1 contract"]
        TerminalAPI["Terminal HTTPS routes<br/>Authenticate terminal client<br/>Authorize push, pull, share<br/>Issue bridge tokens"]
        AuthDO["AuthTokenCoordinator DO<br/>Single-use magic links<br/>Single-use terminal bridge tokens"]
        BranchDO["RepoBranchCoordinator DO<br/>Per-repo/branch write locks<br/>Idempotency and rate counters"]
        KV["Workers KV<br/>Read-mostly non-authoritative config"]
    end

    subgraph OptionalSSH["Optional SSH compatibility data plane"]
        SSH["TypeScript Node SSH service<br/>SSH key authentication<br/>Translate SSH frames<br/>Call Worker terminal routes"]
    end

    subgraph AuthzPlane["Shared authorization plane"]
        Authz["Shared authorization logic<br/>Org/team role<br/>Repo permission<br/>Branch policy<br/>Deny wins"]
    end

    subgraph Async["Async and scheduled work"]
        Queues["Cloudflare Queues<br/>email, audit-events<br/>github-sync, envelope-checks"]
        Workflows["Cloudflare Workflows<br/>Rotation saga<br/>Checkpointed retries"]
        Cron["Cron Triggers<br/>Full GitHub reconcile<br/>Consistency checks<br/>Retention sweeps"]
    end

    subgraph State["Server-side state boundary"]
        Hyperdrive["Hyperdrive<br/>Postgres pooling/cache"]
        Postgres[("Managed Postgres<br/>Identities and sessions<br/>RBAC and GitHub mappings<br/>Branch policies and heads<br/>Envelope metadata<br/>Commit metadata<br/>Immutable audit events")]
        R2[("Cloudflare R2<br/>Encrypted snapshots only<br/>Opaque object names<br/>Optional log exports")]
        Secrets["Secrets Store / Worker secrets<br/>Provider credentials<br/>Webhook secrets<br/>Metadata signing keys"]
    end

    subgraph Crypto["Client-side crypto model"]
        Plaintext["Plaintext env values<br/>exist only in client runtime"]
        Canonical["Canonical snapshot<br/>Sorted key=value bytes<br/>SHA-256 hash"]
        Ciphertext["Encrypted snapshot blob<br/>Repo key AEAD encryption"]
        Envelopes["Envelope chain<br/>SSH or recovery key -> team key<br/>team key -> repo key"]
    end

    Terminal -->|"HTTPS push/pull/share"| HTTP_Edge
    Terminal -.->|"Optional SSH compatibility"| SSH_Edge
    Terminal -->|"Local encrypt/decrypt"| Plaintext
    Terminal -->|"Canonicalize"| Canonical
    Canonical -->|"Encrypt locally"| Ciphertext
    Terminal -->|"Unwrap locally"| Envelopes
    Envelopes -->|"Unlocks repo key"| Ciphertext

    Browser -->|"HTTPS dashboard"| HTTP_Edge
    CI -->|"HTTPS bearer token"| HTTP_Edge
    GitHub -->|"Signed webhooks"| HTTP_Edge
    Worker -->|"Send magic links/invites"| Email

    HTTP_Edge --> Worker
    HTTP_Edge --> TerminalAPI
    HTTP_Edge -.-> Shield
    SSH_Edge -.-> SSH
    SSH -.->|"Translated commands"| TerminalAPI

    Worker --> AuthDO
    Worker --> BranchDO
    Worker --> Authz
    Worker --> Hyperdrive
    Worker --> R2
    Worker --> KV
    Worker --> Queues
    Worker --> Workflows
    Worker -.-> Secrets

    TerminalAPI --> Authz
    TerminalAPI --> AuthDO
    TerminalAPI --> BranchDO
    TerminalAPI --> Hyperdrive
    TerminalAPI --> R2
    TerminalAPI --> Worker

    Authz --> Hyperdrive
    Authz --> BranchDO

    Queues --> Hyperdrive
    Queues --> R2
    Queues -->|"Install token, read-only sync"| GitHub
    Workflows --> BranchDO
    Workflows --> Hyperdrive
    Workflows --> R2
    Cron --> Queues

    Hyperdrive --> Postgres
    Ciphertext -->|"Upload/download ciphertext only"| R2
    Envelopes -->|"Envelope metadata only"| Postgres

    classDef trusted fill:#d9f99d,stroke:#3f6212,color:#1a2e05
    classDef edge fill:#dbeafe,stroke:#1d4ed8,color:#172554
    classDef control fill:#ede9fe,stroke:#6d28d9,color:#2e1065
    classDef state fill:#fee2e2,stroke:#b91c1c,color:#450a0a
    classDef crypto fill:#ccfbf1,stroke:#0f766e,color:#042f2e
    classDef external fill:#fef3c7,stroke:#b45309,color:#451a03

    class Terminal,Browser,CI trusted
    class HTTP_Edge,SSH_Edge,Shield edge
    class Worker,TerminalAPI,AuthDO,BranchDO,KV,SSH,Authz,Queues,Workflows,Cron control
    class Hyperdrive,Postgres,R2,Secrets state
    class Plaintext,Canonical,Ciphertext,Envelopes crypto
    class Email,GitHub external
