{
  "name": "wenvy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "check": "pnpm -r --filter './packages/*' --filter './apps/*' check",
    "cloudflare:init": "tsx scripts/bootstrap-cloudflare.ts --apply",
    "cloudflare:plan": "tsx scripts/bootstrap-cloudflare.ts",
    "cloudflare:preflight": "tsx scripts/bootstrap-cloudflare.ts --preflight",
    "cf:context": "cf context show",
    "cf:whoami": "cf auth whoami",
    "landing:build": "pnpm --filter @wenvy/landing build",
    "landing:dev": "pnpm --filter @wenvy/landing dev",
    "landing:preview": "pnpm --filter @wenvy/landing preview",
    "dashboard:build": "pnpm --filter @wenvy/dashboard build",
    "dashboard:dev": "pnpm --filter @wenvy/dashboard dev",
    "dashboard:preview": "pnpm --filter @wenvy/dashboard preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:types": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
